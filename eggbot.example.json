{
  "ollama": {
    "host": "http://localhost:11434",
    "models": {
      "orchestrator": "qwen2.5:14b",
      "coder": "qwen2.5-coder:14b",
      "fast": "qwen2.5:7b",
      "reasoning": "deepseek-r1:8b"
    }
  },
  "server": {
    "port": 4444,
    "host": "0.0.0.0"
  },
  "agent": {
    "maxWorkers": 8,
    "maxIterations": 50,
    "systemName": "eggbot",
    "heartbeatIntervalMinutes": 15,
    "goalIntervalMinutes": 30
  },
  "mcp": {
    "servers": [
      {
        "_comment": "GitHub MCP — option A: Docker (local, full control)",
        "name": "github",
        "command": "docker",
        "args": ["run", "-i", "--rm", "-e", "GITHUB_PERSONAL_ACCESS_TOKEN", "ghcr.io/github/github-mcp-server"],
        "env": { "GITHUB_PERSONAL_ACCESS_TOKEN": "your-pat-here" }
      },
      {
        "_comment": "GitHub MCP — option B: remote hosted by GitHub (no Docker needed)",
        "name": "github",
        "url": "https://api.githubcopilot.com/mcp/",
        "headers": { "Authorization": "Bearer your-pat-here" }
      },
      {
        "_comment": "Brave Search MCP",
        "name": "brave",
        "command": "npx -y @modelcontextprotocol/server-brave-search",
        "env": { "BRAVE_API_KEY": "your-key-here" }
      }
    ]
  }
}
